      "expectedStatus": 400,
      "expectedBody": {"error": "Имя и телефон обязательны"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Submit lead",
      "method": "POST",
      "path": "/",
      "body": {"name": "Тест", "phone": "+79991234567", "object_type": "Квартира", "message": "Тестовая заявка"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    }
  ]
}
